---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Second Blog Post | asim shirinov">
    <Navbar
        position="absolute"
        showGoUpButton={false}
        alignSocialsRight={true}
    />

    <main
        class="w-full flex justify-center py-20 md:py-24 px-6 flex-grow flex-1"
    >
        <article class="max-w-[820px] w-full flex flex-col gap-6 pt-4">
            <a
                href="/#blog"
                class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium flex items-center gap-1.5 w-fit mb-2"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m15 18-6-6 6-6"></path>
                </svg>
                Back to home
            </a>

            <!-- Header -->
            <header class="flex flex-col gap-3 mb-4">
                <h1
                    class="text-text-primary text-3xl md:text-4xl font-[var(--font-weight-bold)] tracking-tight"
                >
                    Second Blog Post
                </h1>
                <div
                    class="text-text-secondary font-[var(--font-weight-medium)] text-[14px] flex items-center gap-2"
                >
                    <time datetime="2026-03-01">March 1, 2026</time>
                    <span>•</span>
                    <span>About 10 min read</span>
                </div>
            </header>

            <!-- Content -->
            <div
                class="prose text-[1.25em] prose-invert prose-p:text-text-primary prose-p:leading-relaxed prose-headings:text-text-primary prose-a:text-white hover:prose-a:text-gray-300 prose-strong:text-white max-w-none"
