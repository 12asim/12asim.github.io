---
interface Props {
  position?: "fixed" | "absolute" | "static";
  showGoUpButton?: boolean;
  revealOnScroll?: boolean;
  alignSocialsRight?: boolean;
}
const {
  position = "fixed",
  showGoUpButton = true,
  revealOnScroll = false,
  alignSocialsRight = false,
} = Astro.props;

const revealClasses = revealOnScroll
  ? "opacity-0 -translate-x-4 pointer-events-none"
  : "";
---

<header
  id="navbar"
  class={`w-full py-5 ${position} top-0 left-0 z-50 border-b border-border-subtle/55 bg-charcoal transition-all duration-300`}
>
  <div
    class="max-w-[820px] mx-auto px-6 flex justify-between items-center w-full min-h-[40px]"
  >
    <div class="flex items-center gap-3 -ml-3">
      <div
        id="nav-avatar"
        class={`w-10 h-10 rounded-full overflow-hidden border border-border-subtle bg-surface flex items-center justify-center transition-all duration-[400ms] hidden sm:flex ${revealClasses}`}
      >
        <img
          src="/images/tuffbaby.jpeg"
          alt="Asim Shirinov"
          class="w-full h-full object-cover grayscale opacity-90 select-none pointer-events-none"
        />
      </div>

      <h2
        class="text-text-primary text-[25px] font-[var(--font-weight-bold)] tracking-wide"
      >
        Asim Shirinov
      </h2>

      {
        !alignSocialsRight && (
          <div
            id="nav-links"
            class={`flex items-center gap-3 transition-all duration-[400ms] ${revealClasses}`}
          >
            <a
              href="https://github.com/12asim"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-md bg-transparent border border-border-subtle text-text-primary hover:bg-surface/80 transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/asimshirinov/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-md bg-transparent border border-border-subtle text-text-primary hover:bg-surface/80 transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          </div>
        )
      }
    </div>

    <div class="flex items-center gap-3">
      {
        alignSocialsRight && (
          <div
            id="nav-links-right"
            class={`flex items-center gap-3 transition-all duration-[400ms] ${revealClasses}`}
          >
            <a
              href="https://github.com/12asim"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-md bg-transparent border border-border-subtle text-text-primary hover:bg-surface/80 transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
              </svg>
            </a>
            <a
              href="https://www.linkedin.com/in/asimshirinov/"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-md bg-transparent border border-border-subtle text-text-primary hover:bg-surface/80 transition-colors"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
          </div>
        )
      }
      {
        showGoUpButton && (
          <button
            id="nav-top-btn"
            class="flex items-center justify-center w-9 h-9 rounded-md bg-transparent border border-border-subtle text-text-primary hover:bg-surface/80 transition-all duration-[400ms] opacity-0 pointer-events-none cursor-pointer"
            aria-label="Scroll to top"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 19V5M5 12l7-7 7 7" />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</header>

<script>
  const navAvatar = document.getElementById("nav-avatar");
  const navLinks = document.getElementById("nav-links");
  const navTopBtn = document.getElementById("nav-top-btn");

  let isScrolled = false;
  const hasRevealLogic = navAvatar?.classList.contains("opacity-0");

  const handleScroll = () => {
    const scrollRevealThreshold = 180;
    const currentScroll = window.scrollY;

    if (currentScroll > scrollRevealThreshold && !isScrolled) {
      isScrolled = true;

      if (hasRevealLogic) {
        navAvatar?.classList.remove(
          "opacity-0",
          "-translate-x-4",
          "pointer-events-none"
        );
        navAvatar?.classList.add(
          "opacity-100",
          "translate-x-0",
          "pointer-events-auto"
        );

        navLinks?.classList.remove(
          "opacity-0",
          "-translate-x-4",
          "pointer-events-none"
        );
        navLinks?.classList.add(
          "opacity-100",
          "translate-x-0",
          "pointer-events-auto"
        );
      }

      navTopBtn?.classList.remove("opacity-0", "pointer-events-none");
      navTopBtn?.classList.add("opacity-100", "pointer-events-auto");
    } else if (currentScroll <= scrollRevealThreshold && isScrolled) {
      isScrolled = false;

      if (hasRevealLogic) {
        navAvatar?.classList.add(
          "opacity-0",
          "-translate-x-4",
          "pointer-events-none"
        );
        navAvatar?.classList.remove(
          "opacity-100",
          "translate-x-0",
          "pointer-events-auto"
        );

        navLinks?.classList.add(
          "opacity-0",
          "-translate-x-4",
          "pointer-events-none"
        );
        navLinks?.classList.remove(
          "opacity-100",
          "translate-x-0",
          "pointer-events-auto"
        );
      }

      navTopBtn?.classList.add("opacity-0", "pointer-events-none");
      navTopBtn?.classList.remove("opacity-100", "pointer-events-auto");
    }
  };

  navTopBtn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  handleScroll();
  window.addEventListener("scroll", handleScroll, { passive: true });
</script>
