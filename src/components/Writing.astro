---
---

<section
  id="blog"
  class="w-full flex flex-col gap-4 py-4 md:py-6 border-b border-border-subtle/55"
>
  <h2
    class="text-text-primary text-[22px] md:text-[25px] font-bold tracking-tight flex items-center gap-2 mb-2"
  >
    <span role="img" aria-label="blog" class="opacity-90">✍️</span> Blog
  </h2>

  <div class="flex flex-col gap-6 w-full mt-2">
    <!-- Item 1 Card -->
    <a
      href="/blog/first-blog-post"
      class="group flex flex-col gap-2.5 p-5 md:p-6 rounded-xl border border-border-subtle/30 bg-surface/30 hover:bg-surface/60 transition-colors w-full"
    >
      <!-- Content -->
      <h3
        class="text-text-primary text-[21px] md:text-[24px] font-[var(--font-weight-bold)] tracking-tight group-hover:underline underline-offset-4 decoration-border-subtle"
      >
        First Blog Post
      </h3>
      <span
        class="text-text-secondary text-[17px] md:text-[19px] font-[var(--font-weight-medium)] tracking-wide leading-snug"
      >
        Coming soon... an in-depth writeup about engineering, research, and
        technical thoughts.
      </span>

      <!-- Metadata -->
      <span
        class="text-text-secondary text-[16px] md:text-[17px] font-[var(--font-weight-medium)] mt-1.5"
        >2026-02-28 • About 5 min read</span
      >
    </a>
  </div>
</section>
